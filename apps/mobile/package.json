{
  "name": "@migoculto/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start --dev-client --tunnel --scheme migoculto-dev --port 8081",
    "dev:clear": "expo start --dev-client --tunnel --scheme migoculto-dev --clear --port 8081",
    "dev:client": "expo start --dev-client --tunnel --scheme migoculto-dev --port 8081",
    "dev:go": "expo start --go --tunnel --port 8081",
    "dev:lan": "expo start --lan",
    "dev:tunnel": "expo start --tunnel --port 8081",
    "dev:tunnel:clear": "expo start --tunnel --clear --port 8081",
    "start": "expo start --lan",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8091",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check-types": "pnpm typecheck",
    "expo:fix": "expo doctor --fix",
    "prebuild": "expo prebuild",
    "eas:build": "eas build",
    "eas:build:development:android": "eas build --profile development --platform android",
    "eas:build:development:ios": "eas build --profile development --platform ios",
    "build:all": "pnpm eas:build -p all",
    "build:android": "pnpm eas:build -p android",
    "build:ios": "pnpm eas:build -p ios",
    "submit": "eas submit",
    "submit:all": "pnpm submit -p all",
    "submit:android": "pnpm submit -p android",
    "submit:ios": "pnpm submit -p ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@migoculto/api-client": "workspace:*",
    "@migoculto/types": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.5.0",
    "@react-native-google-signin/google-signin": "^16.0.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.25",
    "expo-apple-authentication": "^8.0.7",
    "expo-camera": "^17.0.9",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.18",
    "expo-device": "^8.0.9",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linking": "~8.0.9",
    "expo-notifications": "^0.32.13",
    "expo-router": "~6.0.15",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-updates": "~29.0.13",
    "expo-web-browser": "~15.0.9",
    "firebase": "^12.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mask-input": "^1.2.3",
    "react-native-qrcode-svg": "^6.3.20",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
