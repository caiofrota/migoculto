{
  "name": "migoculto",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "coverage": "vitest run --coverage",
    "dev": "pnpm dev:mobile",
    "dev:all": "turbo run dev",
    "dev:mobile": "pnpm --filter @migoculto/mobile dev",
    "dev:mobile:client": "pnpm --filter @migoculto/mobile dev:client",
    "dev:mobile:clear": "pnpm --filter @migoculto/mobile dev:clear",
    "dev:mobile:go": "pnpm --filter @migoculto/mobile dev:go",
    "dev:mobile:lan": "pnpm --filter @migoculto/mobile dev:lan",
    "dev:mobile:tunnel": "pnpm --filter @migoculto/mobile dev:tunnel",
    "dev:mobile:web": "pnpm --filter @migoculto/mobile web",
    "build:dev:android": "pnpm --filter @migoculto/mobile eas:build:development:android",
    "build:dev:ios": "pnpm --filter @migoculto/mobile eas:build:development:ios",
    "dev:web": "pnpm --filter @migoculto/web dev",
    "db:up": "docker compose up -d",
    "db:generate": "pnpm --filter @migoculto/db db:generate",
    "db:check": "pnpm --filter @migoculto/db db:check",
    "db:migrate": "pnpm --filter @migoculto/db db:migrate",
    "db:deploy": "pnpm --filter @migoculto/db db:deploy",
    "db:seed": "pnpm --filter @migoculto/db db:seed",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:all": "pnpm test && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run --exclude '**/*.integration.spec.ts'",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck",
    "check-types": "pnpm typecheck",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^27.2.0",
    "prettier": "^3.7.4",
    "react-test-renderer": "19.1.0",
    "turbo": "^2.9.14",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.7",
    "vitest-mock-extended": "^3.1.0"
  }
}
